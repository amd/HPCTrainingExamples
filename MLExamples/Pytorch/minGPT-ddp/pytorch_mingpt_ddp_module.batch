#!/bin/bash
#SBATCH --gpus=8
#SBATCH --ntasks=1
#SBATCH --time=01:00:00
#SBATCH --output=pytorch_mingpt_ddp_module.out
#SBATCH --error=pytorch_mingpt_ddp_module.out
#
# minGPT DDP RCCL scaling study using the site ROCm + GPU-Aware OpenMPI + PyTorch
# modules.

set -e

# Site modules (preferred over pip wheels): the openmpi module is GPU-Aware
# (UCX/UCC/xpmem) and the pytorch module is built against this ROCm with a
# ROCm-native DeepSpeed. Pin versions to sample a specific combination; e.g.
#   ROCM_VER=6.4.3 PT_VER=2.12.0   sbatch ...
#   ROCM_VER=7.2.3 PT_VER=2.10.0   sbatch ...
# Available: rocm/{6.4.3,7.0.x,7.1.x,7.2.x}, pytorch/{2.7.1..2.12.0}
# (each pytorch version also has a _tunableop_enabled variant for GEMM autotune).
module load rocm/${ROCM_VER:-7.2.3} openmpi pytorch/${PT_VER:-2.12.0}

python3 -c 'import torch; print("Torch:", torch.__version__, "HIP:", getattr(torch.version,"hip",None), \
  "count:", torch.cuda.device_count())'

if [[ ! -f "$HOME/pytorch_examples/distributed/minGPT-ddp/mingpt/model.py" ]]; then
  git clone --depth=1 https://github.com/pytorch/examples.git "$HOME/pytorch_examples"
fi
export UPSTREAM="$HOME/pytorch_examples/distributed/minGPT-ddp/mingpt"

export NCCL_DEBUG=INFO
export NCCL_DEBUG_SUBSYS=INIT,COLL

cd "$SLURM_SUBMIT_DIR"
echo "===== minGPT DDP scaling (gpt2-size) ====="
GPUS="1 2 4 8" bash ./rccl_scaling_sweep.sh

echo "===== larger model (more gradient volume => more RCCL) ====="
GPUS="1 2 4 8" N_LAYER=24 N_EMBD=1024 N_HEAD=16 bash ./rccl_scaling_sweep.sh

echo "Finished"
